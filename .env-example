# Copy this file to .env and replace the example values.
#
# cp .env-example .env
#
# Values already exported in the shell take precedence over this file.

MSSQL_HOST=sql-server.example.internal
MSSQL_PORT=1433
MSSQL_DB=Turista
MSSQL_USER=pgloader_user
MSSQL_PASSWORD=replace-with-sql-server-password

# Name of the [section] in freetds.conf used by mssql-to-postgres.load.template
# (the LOAD DATABASE FROM clause connects through this FreeTDS alias, not
# directly through MSSQL_HOST/MSSQL_PORT).
MSSQL_FREETDS_ALIAS=turista

PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=turista
PGUSER=turista_pgloader
PGPASSWORD=replace-with-postgresql-password

# What run-pgloader-fullmigration.sh should do when check-timezones.sh finds
# a date/time mismatch between SQL Server and PostgreSQL after the migration:
#   abort  - stop the migration and exit non-zero (default)
#   warn   - log a warning and continue
#   ignore - skip the timezone check entirely
TIMEZONE_MISMATCH_ACTION=abort
